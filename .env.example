# Anthropic API key — used by src/recommend.ts to tag events recommended:true/false
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth credentials for Calendar API
# Create at https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client ID
# Application type: Web app, redirect URI: http://localhost:3000
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Filled in automatically by `npm run auth-calendar`
GOOGLE_REFRESH_TOKEN=
